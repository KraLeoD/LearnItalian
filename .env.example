# Local development only. Copy to .env; never commit real keys.
NODE_ENV=development
PORT=8080
APP_PORT=8080
HOST=0.0.0.0
DATA_DIR=./data
PROVIDER_MODE=mock
DEV_ORIGIN=http://localhost:8081
EXPO_PUBLIC_API_URL=http://localhost:8080

# Required only when PROVIDER_MODE=azure
AZURE_TRANSLATOR_KEY=replace-with-translator-key
AZURE_SPEECH_KEY=replace-with-speech-key
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_REGION=westeurope
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_REGION=westeurope
AZURE_SPEECH_VOICE=it-IT-ElsaNeural

# Conservative application-side safeguards (characters/calendar month)
TRANSLATION_MONTHLY_CHAR_LIMIT=1500000
SPEECH_MONTHLY_CHAR_LIMIT=400000
MAX_TEXT_LENGTH=2000
GENERATION_REQUESTS_PER_MINUTE=10
PROVIDER_TIMEOUT_MS=10000
